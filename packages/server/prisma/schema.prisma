// ArmiAI Platform — Prisma Schema
// Redesigned for project-based workflow with documentation-first approach.
// See docs/schema/SCHEMA-AND-API.md for full design rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Company — Top-level tenant
// ──────────────────────────────────────────────────────────────
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  mission   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents          Agent[]
  projects        Project[]
  budgets         Budget[]
  approvals       Approval[]
  activityEvents  ActivityEvent[]
  routines        Routine[]
  secrets         Secret[]
  workspaces      Workspace[]
  userCompanies   UserCompany[]
}

// ──────────────────────────────────────────────────────────────
// User — Platform user (for multi-company access)
// ──────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("USER") // ADMIN, USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCompanies UserCompany[]
}

// ──────────────────────────────────────────────────────────────
// UserCompany — Junction table for multi-company access
// ──────────────────────────────────────────────────────────────
model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("MEMBER") // OWNER, ADMIN, MEMBER
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

// ──────────────────────────────────────────────────────────────
// Workspace — Physical/logical working area
// ──────────────────────────────────────────────────────────────
model Workspace {
  id        String   @id @default(cuid())
  companyId String
  path      String   // Absolute path to the physical workspace on disk
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ──────────────────────────────────────────────────────────────
// Agent — AI actor in the Org Chart
// ──────────────────────────────────────────────────────────────
model Agent {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  role        String   // e.g., 'orchestrator', 'developer', 'qa-engineer'
  title       String?
  managerId   String?  // Self-relation for org chart
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, TERMINATED
  isTemplate  Boolean  @default(false) // true = predefined template, false = company instance
  templateKey String?  // Unique key for template lookup (e.g., 'orchestrator', 'frontend-dev')
  config      Json?    // Agent config: instructions, tools, skills, systemPrompt
  createdAt   DateTime @default(now())

  company    Company    @relation(fields: [companyId], references: [id])
  manager    Agent?     @relation("OrgChart", fields: [managerId], references: [id])
  reports    Agent[]    @relation("OrgChart")
  tasks      Task[]     @relation("TaskAssignee")
  budgets    Budget[]
  heartbeats Heartbeat[]
  questions  AgentQuestion[]
  orchestratedProjects Project[] // Projects where this agent is the orchestrator

  @@index([companyId])
  @@index([managerId])
  @@index([isTemplate])
  @@index([templateKey])
}

// ──────────────────────────────────────────────────────────────
// Project — High-level container (Redesigned for workflow)
// ──────────────────────────────────────────────────────────────
model Project {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  description     String?  // User's project description (becomes the main prompt)
  folderPath      String?  // Absolute path where code will be generated
  status          String   @default("DRAFT") // DRAFT, PLANNING, DOCUMENTATION, AWAITING_APPROVAL, DEVELOPMENT, TESTING, COMPLETED, PAUSED
  phase           String   @default("INITIALIZATION") // INITIALIZATION, DOCUMENTATION, APPROVAL, DEVELOPMENT, TESTING, DEPLOYMENT
  orchestratorId  String?  // The main orchestrator agent for this project
  documentation   ProjectDocumentation?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company      Company      @relation(fields: [companyId], references: [id])
  orchestrator Agent?       @relation(fields: [orchestratorId], references: [id])
  goals        Goal[]
  questions    AgentQuestion[]

  @@index([companyId])
  @@index([status])
  @@index([phase])
}

// ──────────────────────────────────────────────────────────────
// ProjectDocumentation — Documentation artifacts for a project
// ──────────────────────────────────────────────────────────────
model ProjectDocumentation {
  id              String   @id @default(cuid())
  projectId       String   @unique
  prd             String?  // Product Requirements Document (markdown)
  architecture    String?  // Architecture document (markdown)
  techStack       String?  // Technology stack decisions (markdown)
  stories         String?  // Generated user stories / dev tasks (markdown)
  status          String   @default("DRAFT") // DRAFT, GENERATING, READY, APPROVED, REJECTED
  rejectionReason String?  // Why user rejected the documentation
  generatedAt     DateTime? // When documentation was fully generated
  approvedAt      DateTime? // When user approved the documentation
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ──────────────────────────────────────────────────────────────
// AgentQuestion — Questions agents ask the user
// ──────────────────────────────────────────────────────────────
model AgentQuestion {
  id          String   @id @default(cuid())
  projectId   String
  agentId     String
  heartbeatId String?  // Optional: linked to a specific execution
  question    String   // The question text
  context     String?  // Additional context for why this question is asked
  answer      String?  // User's answer
  status      String   @default("PENDING") // PENDING, ANSWERED, SKIPPED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, BLOCKING
  createdAt   DateTime @default(now())
  answeredAt  DateTime?

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent     Agent    @relation(fields: [agentId], references: [id])
  heartbeat Heartbeat? @relation(fields: [heartbeatId], references: [id])

  @@index([projectId])
  @@index([agentId])
  @@index([status])
  @@index([projectId, status]) // Compound: pending questions per project
}

// ──────────────────────────────────────────────────────────────
// Goal — Mid-level objective
// ──────────────────────────────────────────────────────────────
model Goal {
  id        String   @id @default(cuid())
  projectId String
  name      String
  status    String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  phase     String   @default("DEVELOPMENT") // DOCUMENTATION, DEVELOPMENT, TESTING

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

// ──────────────────────────────────────────────────────────────
// Task — Actionable item
// ──────────────────────────────────────────────────────────────
model Task {
  id          String   @id @default(cuid())
  goalId      String
  assigneeId  String?
  title       String
  description String?
  status      String   @default("BACKLOG") // BACKLOG, TODO, IN_PROGRESS, REVIEW, DONE
  priority    String   @default("MEDIUM")  // LOW, MEDIUM, HIGH, CRITICAL
  lockedAt    DateTime? // Used for atomic checkout
  artifacts   Json?     // Array of paths (e.g., ['docs/stories/STORY-001.md'])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goal       Goal        @relation(fields: [goalId], references: [id], onDelete: Cascade)
  assignee   Agent?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  heartbeats Heartbeat[]

  @@index([goalId])
  @@index([assigneeId])
  @@index([status])
  @@index([goalId, status])       // Compound: list tasks by goal+status (Kanban queries)
  @@index([assigneeId, status])   // Compound: agent task queue (auto-pick queries)
}

// ──────────────────────────────────────────────────────────────
// Heartbeat — A single execution run
// ──────────────────────────────────────────────────────────────
model Heartbeat {
  id         String   @id @default(cuid())
  taskId     String
  agentId    String
  status     String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, PAUSED_FOR_QUESTIONS
  startedAt  DateTime?
  endedAt    DateTime?
  log        String?
  tokensUsed Int      @default(0)
  cost       Float    @default(0.0)

  task        Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent       Agent         @relation(fields: [agentId], references: [id])
  costEvents  CostEvent[]
  routineRuns RoutineRun[]
  questions   AgentQuestion[]

  @@index([taskId])
  @@index([agentId])
  @@index([status])
  @@index([agentId, status])      // Compound: agent stats + orphan recovery queries
  @@index([status, startedAt])    // Compound: orphan detection (RUNNING + stale time)
}

// ──────────────────────────────────────────────────────────────
// Budget — Financial constraints
// ──────────────────────────────────────────────────────────────
model Budget {
  id        String   @id @default(cuid())
  companyId String
  agentId   String?  // If null, represents the global company budget
  monthly   Float
  used      Float    @default(0.0)
  currency  String   @default("USD")
  threshold Float    @default(0.8) // 80%
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  agent   Agent?  @relation(fields: [agentId], references: [id])

  @@index([companyId])
  @@index([agentId])
}

// ──────────────────────────────────────────────────────────────
// CostEvent — Record of expenditure
// ──────────────────────────────────────────────────────────────
model CostEvent {
  id          String   @id @default(cuid())
  heartbeatId String
  provider    String
  model       String
  tokensIn    Int
  tokensOut   Int
  cost        Float
  createdAt   DateTime @default(now())

  heartbeat Heartbeat @relation(fields: [heartbeatId], references: [id], onDelete: Cascade)

  @@index([heartbeatId])
}

// ──────────────────────────────────────────────────────────────
// Approval — Governance gate
// ──────────────────────────────────────────────────────────────
model Approval {
  id          String   @id @default(cuid())
  companyId   String
  projectId   String?  // Linked to project for phase approvals
  type        String   // TASK_EXECUTION, DOCUMENTATION_REVIEW, PHASE_TRANSITION, BUDGET_INCREASE
  requestedBy String   // Agent or System
  targetType  String   // TASK, PROJECT, DOCUMENTATION, PHASE
  targetId    String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  decision    String?
  reason      String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([projectId])
}

// ──────────────────────────────────────────────────────────────
// ActivityEvent — Audit log entry
// ──────────────────────────────────────────────────────────────
model ActivityEvent {
  id         String   @id @default(cuid())
  companyId  String
  actorType  String   // 'USER' or 'AGENT' or 'SYSTEM'
  actorId    String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([companyId, createdAt])
}

// ──────────────────────────────────────────────────────────────
// Routine — Scheduled job
// ──────────────────────────────────────────────────────────────
model Routine {
  id                 String   @id @default(cuid())
  companyId          String
  agentId            String?
  name               String
  description        String?
  cron               String
  action             String
  enabled            Boolean  @default(true)
  concurrencyPolicy  String   @default("ALLOW_OVERLAP")
  catchUpPolicy      String   @default("SKIP")
  maxConcurrentRuns  Int      @default(1)
  timeoutMs          Int?
  lastRunAt          DateTime?
  nextRunAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company      @relation(fields: [companyId], references: [id])
  runs    RoutineRun[]

  @@index([companyId])
  @@index([enabled])
  @@index([nextRunAt])
  @@index([companyId, enabled])
}

// ──────────────────────────────────────────────────────────────
// RoutineRun — History of a routine execution
// ──────────────────────────────────────────────────────────────
model RoutineRun {
  id          String    @id @default(cuid())
  routineId   String
  heartbeatId String?
  status      String    @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, SKIPPED
  startedAt   DateTime?
  endedAt     DateTime?
  log         String?
  error       String?
  createdAt   DateTime  @default(now())

  routine   Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)
  heartbeat Heartbeat? @relation(fields: [heartbeatId], references: [id])

  @@index([routineId])
  @@index([status])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────
// Secret — Encrypted configuration
// ──────────────────────────────────────────────────────────────
model Secret {
  id             String @id @default(cuid())
  companyId      String
  name           String
  encryptedValue String
  scope          String // 'GLOBAL' or 'AGENT'

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@unique([companyId, name])
}
